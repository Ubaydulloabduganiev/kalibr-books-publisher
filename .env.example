# Application
APP_NAME=Kalibr Publisher
APP_ENV=development
APP_VERSION=0.1.0
APP_DOMAIN=publisher.uboom.uz
APP_TIMEZONE=Asia/Tashkent
APP_DEFAULT_LOCALE=uz
APP_SUPPORTED_LOCALES=uz,ru

# API
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
API_ALLOWED_HOSTS=localhost,127.0.0.1,api,publisher.uboom.uz
API_CORS_ORIGINS=http://localhost:3000,https://publisher.uboom.uz
API_DOCS_ENABLED=true
API_LOG_LEVEL=INFO
API_LOG_FORMAT=console
API_REQUEST_ID_HEADER=X-Request-ID

# Persistent paths inside containers
STORAGE_ROOT=/data/storage
BACKUP_ROOT=/data/backups
TEMP_ROOT=/data/tmp
LOG_ROOT=/data/logs

# Frontend server-side API access
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_APP_NAME=Kalibr Publisher
NEXT_PUBLIC_DEFAULT_LOCALE=uz

# Caddy and TLS
CADDY_EMAIL=admin@uboom.uz

# Telegram (Bot API)
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL=
